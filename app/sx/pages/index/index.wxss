/* index.wxss */
.container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 40rpx;
}

.banner {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
  filter: brightness(0.7);
}

.banner-content {
  position: absolute;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  color: white;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
}

.banner-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  text-shadow: 0 1rpx 5rpx rgba(0, 0, 0, 0.3);
}

.features-section {
  margin: 30rpx 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 30rpx;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.feature-item {
  background-color: var(--bg-color-white);
  border-radius: 12rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--border-color);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.feature-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.feature-title {
  font-size: 26rpx;
  color: var(--text-color);
}

.orders-section {
  margin: 40rpx 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-more {
  font-size: 24rpx;
  color: var(--text-color-light);
}

.latest-orders {
  background-color: var(--bg-color-white);
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid var(--border-color);
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.order-item:last-child {
  border-bottom: none;
}

.order-main {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-info {
  display: flex;
  flex-direction: column;
}

.order-id {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 8rpx;
}

.order-date {
  font-size: 24rpx;
  color: var(--text-color-light);
}

.order-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 20rpx;
}

.order-status.text-primary {
  color: var(--primary-color);
  background-color: rgba(26, 173, 25, 0.1);
}

.order-status.text-warning {
  color: var(--warning-color);
  background-color: rgba(255, 149, 0, 0.1);
}

.order-status.text-error {
  color: var(--error-color);
  background-color: rgba(255, 59, 48, 0.1);
}

.order-status.text-light {
  color: var(--text-color-light);
  background-color: var(--bg-color-gray);
}
