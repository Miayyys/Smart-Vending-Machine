/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 100rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background-color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.logo-text {
  font-size: 80rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.login-section {
  width: 100%;
  max-width: 600rpx;
  text-align: center;
}

.form-desc {
  font-size: 32rpx;
  color: white;
  text-align: center;
  margin-bottom: 80rpx;
}

.wechat-btn {
  width: 100%;
  height: 100rpx;
  background-color: #07c160;
  color: white;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  outline: none;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
}

.wechat-btn::after {
  display: none;
}

.wechat-btn:active {
  opacity: 0.8;
}

.hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
}

.error-text {
  color: #ff4444;
  font-size: 28rpx;
  text-align: center;
  margin-top: 40rpx;
}

.footer {
  margin-top: 100rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-bottom: 10rpx;
}

.footer-link {
  font-size: 24rpx;
  color: white;
  text-decoration: underline;
}