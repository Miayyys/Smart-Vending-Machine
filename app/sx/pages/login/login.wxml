<!--pages/login/login.wxml-->
<view class="container">
  <!-- Logo和标题 -->
  <view class="header">
    <view class="logo">
      <text class="logo-text">📦</text>
    </view>
    <text class="title">校园智能柜</text>
    <text class="subtitle">便捷购物新体验</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-section">
    <text class="form-desc">点击下方按钮使用微信账号登录</text>

    <button class="wechat-btn" bindtap="onWechatLogin" loading="{{loading}}">
      {{loading ? '登录中...' : '微信一键登录'}}
    </button>

    <text class="hint">登录后将生成唯一用户ID</text>

    <text class="error-text" wx:if="{{error}}">{{error}}</text>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">使用微信登录即表示同意</text>
    <text class="footer-link" bindtap="showTerms">《用户协议》</text>
  </view>
</view>