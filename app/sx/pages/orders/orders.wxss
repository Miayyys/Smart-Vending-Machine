/* pages/orders/orders.wxss */
.container {
  min-height: 100vh;
  background-color: var(--bg-color);
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.header {
  padding: 20rpx;
  background-color: white;
  border-bottom: 1rpx solid var(--border-color);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-color);
}

.content-container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.orders-list {
  flex: 1;
  height: 100%;
}

.order-item {
  background-color: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.order-info {
  flex: 1;
}

.order-id {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: bold;
  display: block;
  margin-bottom: 6rpx;
}

.order-time {
  font-size: 24rpx;
  color: var(--text-color-light);
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  white-space: nowrap;
  margin-left: 20rpx;
}

.order-status.paid {
  color: var(--primary-color);
  background-color: rgba(26, 173, 25, 0.1);
}

.order-status.unpaid {
  color: var(--warning-color);
  background-color: rgba(255, 149, 0, 0.1);
}

.order-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-top: 1rpx solid var(--border-color);
}

.order-items {
  font-size: 26rpx;
  color: var(--text-color-secondary);
  flex: 1;
}

.order-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border-color);
}

.view-detail-btn {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  background-color: var(--primary-color);
  color: white;
  border-radius: 28rpx;
  border: none;
}

.view-detail-btn:active {
  transform: scale(0.98);
}

/* 加载、错误、空状态样式 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  color: var(--text-color-light);
  font-size: 26rpx;
}

.error {
  text-align: center;
  padding: 40rpx;
  color: var(--error-color);
}

.error-text {
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.retry-btn {
  margin-top: 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--text-color-light);
}

.empty-state-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-state-text {
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.empty-state-tip {
  font-size: 24rpx;
  color: var(--text-color-light);
  text-align: center;
  line-height: 1.5;
}
