<!--pages/product-detail/product-detail.wxml-->
<view class="container" wx:if="{{!loading && !error}}">
  <!-- 商品图片 -->
  <view class="product-header">
    <view class="product-image">
      <image
        src="{{product.imageUrl || ''}}"
        mode="aspectFit"
        binderror="onImageError"
        lazy-load
      />
      <text class="product-icon" wx:if="{{!product.imageUrl}}">📦</text>
    </view>
    <view class="product-info">
      <text class="product-name">{{product.name}}</text>
      <text class="product-desc">{{product.description}}</text>
      <text class="product-price text-bold text-primary">¥{{product.price}}</text>
      <text class="product-sku">SKU: {{product.sku}}</text>
    </view>
  </view>

  <!-- 库存信息 -->
  <view class="stock-section card">
    <view class="stock-info">
      <text class="stock-label">库存数量</text>
      <text class="stock-value {{availableStock > 0 ? 'text-success' : 'text-error'}}">
        {{availableStock > 0 ? '仅剩 ' + availableStock + ' 件' : '已售罄'}}
      </text>
    </view>
  </view>

  <!-- 数量选择 -->
  <view class="quantity-section card" wx:if="{{availableStock > 0}}">
    <text class="quantity-label">购买数量</text>
    <view class="quantity-control">
      <button class="quantity-btn" bindtap="decreaseQuantity" disabled="{{selectedQuantity <= 1}}">
        <text class="quantity-icon">-</text>
      </button>
      <input
        class="quantity-input"
        type="number"
        value="{{selectedQuantity}}"
        bindinput="onQuantityInput"
        min="1"
        max="{{maxQuantity}}"
      />
      <button class="quantity-btn" bindtap="increaseQuantity" disabled="{{selectedQuantity >= maxQuantity}}">
        <text class="quantity-icon">+</text>
      </button>
    </view>
    <text class="quantity-hint">最多可购买 {{maxQuantity}} 件</text>
  </view>

  <!-- 商品详情 -->
  <view class="detail-section card">
    <text class="detail-title">商品详情</text>
    <view class="detail-content">
      <text class="detail-text">{{product.description || '暂无详细描述'}}</text>
      <view class="detail-item">
        <text class="detail-label">商品规格：</text>
        <text class="detail-value">{{product.sku || '标准规格'}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">上架时间：</text>
        <text class="detail-value">{{product.createTime}}</text>
      </view>
    </view>
  </view>

  <!-- 底部购买栏 -->
  <view class="footer-bar">
    <view class="total-price">
      <text class="price-label">合计：</text>
      <text class="price-value text-primary text-bold">¥{{product.price * selectedQuantity}}</text>
    </view>
    <button
      class="buy-btn btn btn-primary"
      bindtap="onBuyNow"
      loading="{{loading}}"
      disabled="{{availableStock === 0 || loading}}"
    >
      {{loading ? '处理中...' : '立即购买'}}
    </button>
    <button
      class="cart-btn btn btn-default"
      bindtap="onAddToCart"
      disabled="{{loading}}"
    >
      加入购物车
    </button>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading}}">
  <view class="loading-content">
    <text class="loading-icon">⏳</text>
    <text class="loading-text">加载商品详情...</text>
  </view>
</view>

<!-- 错误状态 -->
<view class="error-container" wx:if="{{error}}">
  <view class="error-content">
    <text class="error-icon">❌</text>
    <text class="error-title">加载失败</text>
    <text class="error-message">{{error}}</text>
    <button class="retry-btn btn btn-primary" bindtap="loadProductDetail">重试</button>
  </view>
</view>