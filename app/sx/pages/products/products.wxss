/* pages/products/products.wxss */
.container {
  height: 100vh;
  width: 100%;
  background-color: var(--bg-color);
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
}

.header {
  width: 100%;
  box-sizing: border-box;
  background-color: var(--bg-color-white);
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid var(--border-color);
  flex-shrink: 0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-color);
}

.open-door-btn {
  width: 160rpx;
  font-size: 26rpx;
}

/* 主内容区域 */
.content-container {
  flex: 1;
  width: 100%;
  overflow: hidden;
}

/* 商品列表容器 */
/* 主内容区域 */
.content-container {
  flex: 1;
  width: 100%;
  overflow: hidden;
}

.products-list {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 20rpx;
}

.product-item {
  display: flex;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 30rpx;
  min-height: 160rpx;
  padding: 20rpx;
  background-color: var(--bg-color-white);
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  align-items: center;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-color-gray);
  border-radius: 8rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.product-image image {
  width: 100%;
  height: 100%;
}

.product-icon {
  font-size: 50rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-right: 20rpx;
}

.product-name {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 20rpx;
}

.product-price {
  font-size: 38rpx;
  color: var(--primary-color);
  font-weight: bold;
  margin-bottom: 15rpx;
}

.product-stock {
  display: flex;
  align-items: center;
}

.stock-label {
  font-size: 26rpx;
  color: var(--text-color-light);
  margin-right: 10rpx;
}

.stock-value {
  font-size: 26rpx;
  font-weight: bold;
}

.stock-value.text-success {
  color: #07c160;
}

.stock-value.text-error {
  color: var(--error-color);
}

.product-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-end;
  min-width: 120rpx;
}

.btn.btn-primary {
  width: 120rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  border-radius: 28rpx;
  background-color: var(--primary-color);
  color: white;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(1, 122, 255, 0.3);
}

.btn.btn-primary:active {
  transform: scale(0.98);
}

/* 底部操作栏 */
.bottom-actions {
  width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
  background-color: var(--bg-color-white);
  border-top: 1rpx solid var(--border-color);
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.open-door-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 40rpx;
  background-color: var(--primary-color);
  color: white;
  border: none;
  outline: none;
  box-shadow: 0 4rpx 16rpx rgba(26, 173, 25, 0.3);
}

.open-door-btn:active {
  transform: scale(0.98);
  background-color: var(--secondary-color);
}