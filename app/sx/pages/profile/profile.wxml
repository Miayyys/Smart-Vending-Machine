<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息区 -->
  <view class="user-section">
    <view class="user-avatar">
      <image src="{{userInfo.avatarUrl || ''}}" mode="aspectFill" />
      <!-- 使用默认头像图标 -->
      <text class="avatar-icon" wx:if="{{!userInfo.avatarUrl}}">👤</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName}}</text>
      <view class="user-id-section">
        <text class="user-id">用户ID: {{userId}}</text>
        <text class="copy-btn" bindtap="copyUserId">复制</text>
      </view>
    </view>
  </view>

  <!-- 订单统计 -->
  <view class="stats-section card">
    <view class="stats-title">订单统计</view>
    <view class="stats-grid">
      <view class="stats-item">
        <text class="stats-number">{{orderStats.total}}</text>
        <text class="stats-label">全部订单</text>
      </view>
      <view class="stats-item">
        <text class="stats-number text-warning">{{orderStats.unpaid}}</text>
        <text class="stats-label">待支付</text>
      </view>
      <view class="stats-item">
        <text class="stats-number text-primary">{{orderStats.paid}}</text>
        <text class="stats-label">已完成</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="function-section">
    <view class="function-item" bindtap="goToSettings">
      <view class="function-icon">⚙️</view>
      <view class="function-info">
        <text class="function-name">设置</text>
        <text class="function-desc">管理账户和偏好设置</text>
      </view>
      <view class="function-arrow">></view>
    </view>

    <view class="function-item" bindtap="goToAbout">
      <view class="function-icon">ℹ️</view>
      <view class="function-info">
        <text class="function-name">关于我们</text>
        <text class="function-desc">了解校园智能柜 v1.0.0</text>
      </view>
      <view class="function-arrow">></view>
    </view>

    <view class="function-item logout-item" bindtap="logout">
      <view class="function-icon">🚪</view>
      <view class="function-info">
        <text class="function-name">退出登录</text>
        <text class="function-desc">安全退出当前账号</text>
      </view>
      <view class="function-arrow">></view>
    </view>
  </view>

  <!-- 分享 -->
  <view class="share-section">
    <button class="share-btn" bindtap="onShareAppMessage">
      分享给好友
    </button>
  </view>
</view>