<!--pages/order-detail/order-detail.wxml-->
<view class="container">
  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error" wx:if="{{error}}">
    <text class="error-text">{{error}}</text>
    <button class="retry-btn btn btn-default" bindtap="retryLoad">重试</button>
  </view>

  <!-- 订单详情 -->
  <view class="order-detail" wx:if="{{!loading && !error && order}}">
    <!-- 订单基本信息 -->
    <view class="order-header card">
      <view class="order-info">
        <text class="order-id">订单号: {{order.batchId}}</text>
        <text class="order-time">{{order.createTime}}</text>
        <view class="order-status {{statusTag.color}}">
          {{statusTag.text}}
        </view>
      </view>
      <view class="order-total">
        <text class="total-label">总计</text>
        <text class="total-amount">¥{{order.totalAmount}}</text>
      </view>
    </view>

    <!-- 商品明细 -->
    <view class="order-items card">
      <view class="section-title">商品明细</view>
      <view class="items-list">
        <view class="item-row" wx:for="{{order.items}}" wx:key="productId">
          <view class="item-info">
            <text class="item-name">{{item.productName}}</text>
            <text class="item-price">¥{{item.price}}</text>
          </view>
          <text class="item-qty">x{{item.qty || item.quantity}}</text>
          <text class="item-subtotal">¥{{item.subtotal}}</text>
        </view>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="order-info card">
      <view class="section-title">订单信息</view>
      <view class="info-item">
        <text class="info-label">批次号</text>
        <text class="info-value">{{order.batchId}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">创建时间</text>
        <text class="info-value">{{order.createTime}}</text>
      </view>
      <view class="info-item" wx:if="{{order.settleTime}}">
        <text class="info-label">支付时间</text>
        <text class="info-value">{{order.settleTime}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="order-actions">
      <button class="btn btn-primary btn-block" wx:if="{{order.payStatus === 'UNPAID'}}" bindtap="payOrder">
        支付
      </button>
      <button class="btn btn-default btn-block" bindtap="goBack">
        返回订单列表
      </button>
    </view>
  </view>
</view>