/* pages/settings/settings.wxss */
.container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 40rpx;
}

.back-section {
  padding: 20rpx;
}

.back-btn {
  background-color: var(--primary-color);
  color: white;
  border: none;
  outline: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  width: 100%;
}

.back-btn:active {
  opacity: 0.8;
}

.user-section {
  margin: 20rpx;
  padding: 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 30rpx;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
  display: block;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 24rpx;
  color: var(--text-color-light);
  display: block;
  margin-bottom: 6rpx;
}

.login-time {
  font-size: 24rpx;
  color: var(--text-color-light);
}

.settings-section {
  margin: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.setting-item {
  background-color: var(--bg-color-white);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--border-color);
  margin-bottom: 16rpx;
}

.setting-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.setting-name {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: var(--text-color-light);
}

.setting-arrow {
  font-size: 28rpx;
  color: var(--text-color-light);
  margin-left: 20rpx;
}

.logout-section {
  margin: 40rpx 20rpx;
}

.logout-btn {
  background-color: var(--error-color);
  color: white;
  border: none;
  outline: none;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
}

.logout-btn:active {
  opacity: 0.8;
}

.back-section {
  margin: 20rpx;
  padding-bottom: 20rpx;
}

.back-btn {
  background-color: var(--primary-color);
  color: white;
  border: none;
  outline: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  width: 100%;
}

.back-btn:active {
  opacity: 0.8;
}