/* components/loading/loading.wxss */
.loading-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  background-color: rgba(0, 0, 0, 0.1);
}

.loading-container.loading-mask {
  background-color: rgba(255, 255, 255, 0.8);
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-color-secondary);
  margin-top: 20rpx;
}

/* Spinner 加载器 */
.spinner {
  width: 60rpx;
  height: 60rpx;
  position: relative;
}

.spinner-circle {
  width: 100%;
  height: 100%;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

/* Dots 加载器 */
.dots {
  display: flex;
  align-items: center;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--primary-color);
  margin: 0 6rpx;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

/* Pulse 加载器 */
.pulse {
  width: 60rpx;
  height: 60rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  animation: pulse 1.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes pulse {
  0% {
    transform: scale(0);
    opacity: 1;
  }
  70% {
    transform: scale(1);
    opacity: 0.7;
  }
  100% {
    transform: scale(0);
    opacity: 0;
  }
}

/* 环形进度条 */
.circle-loading {
  width: 100rpx;
  height: 100rpx;
  position: relative;
}

.circle-loading::before {
  content: '';
  position: absolute;
  width: 100rpx;
  height: 100rpx;
  border: 8rpx solid var(--bg-color-gray);
  border-radius: 50%;
}

.circle-loading::after {
  content: '';
  position: absolute;
  width: 100rpx;
  height: 100rpx;
  border: 8rpx solid var(--primary-color);
  border-radius: 50%;
  border-top-color: transparent;
  border-right-color: transparent;
  animation: spin 1s linear infinite;
}

.circle-loading .loading-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  margin-top: 0;
}