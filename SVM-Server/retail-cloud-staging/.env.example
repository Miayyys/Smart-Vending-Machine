# ===== 零售柜云平台 .env 配置模板 =====
# 部署步骤: cp .env.example .env → 修改密码 → chmod 600 .env

# --- MySQL ---
MYSQL_ROOT_PASSWORD=<your-mysql-root-password>
MYSQL_DATABASE=retail_cloud
MYSQL_USER=retail
MYSQL_PASSWORD=<your-mysql-app-password>

# --- Backend ---
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/retail_cloud?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=UTF-8&useUnicode=true
SPRING_DATASOURCE_USERNAME=retail
SPRING_DATASOURCE_PASSWORD=<your-mysql-app-password>
JAVA_OPTS=-Xms128m -Xmx256m -XX:MaxRAMPercentage=60 -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai

# --- EMQX (内置账号鉴权) ---
EMQX_UI_USERNAME=retail_ui
EMQX_UI_PASSWORD=<your-emqx-ui-password>
EMQX_DEV_USERNAME=retail_device
EMQX_DEV_PASSWORD=<your-emqx-device-password>
EMQX_DASHBOARD_USERNAME=admin
EMQX_DASHBOARD_PASSWORD=<your-emqx-dashboard-password>

# --- 楼层抓拍 ---
SNAPSHOT_KEEP=200
SNAPSHOT_TOKEN_D01=<your-snapshot-token-D01>
SNAPSHOT_TOKEN_D02=<your-snapshot-token-D02>
